#. module: hr_expense_stripe
#. odoo-javascript
#: code:addons/hr_expense_stripe/static/src/components/open_card_receive_terms.xml:0
msgid ""
"You must report lost or stolen cards immediately.\n"
"                    You are responsible for monitoring usage and disputing "
"unauthorized charges promptly."
msgstr ""
"Kadonneet tai varastetut kortit on ilmoitettava välittömästi.\n"
"                    Olet vastuussa kortin käytön valvonnasta ja luvattomien "
"veloitusten riitauttamisesta viipymättä."

#. module: hr_expense_stripe
#. odoo-python
#: code:addons/hr_expense_stripe/models/res_company.py:0
msgid "You need to be connected to stripe in order to configure your account."
msgstr "Sinun on oltava yhdistettynä Stripeen määrittääksesi tilisi asetukset."

