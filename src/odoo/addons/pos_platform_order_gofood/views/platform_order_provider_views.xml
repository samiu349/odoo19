<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="platform_order_provider_form_inherit" model="ir.ui.view">
        <field name="name">platform.order.provider.form.inherit.pos_platform_order_gofood</field>
        <field name="model">platform.order.provider</field>
        <field name="inherit_id" ref="pos_platform_order.view_platform_order_provider_form"/>
        <field name="arch" type="xml">
            <group name="provider_credentials" position='inside'>
                <group invisible="code != 'gofood'">
                    <field name="gofood_appid"
                        string="App ID"
                        required="code == 'gofood' and state != 'disabled'"/>
                    <field name="gofood_secret"
                        string="Secret Key"
                        required="code == 'gofood' and state != 'disabled'"
                        password="True"/>
                    <field name="gofood_partner_id"
                        string="Partner ID"
                        required="code == 'gofood' and state != 'disabled'"/>
                    <field name="gofood_relay_secret"
                        string="Relay Secret Key"
                        required="code == 'gofood' and state != 'disabled'"
                        password="True"/>
                </group>
            </group>
        </field>
    </record>

</odoo>
