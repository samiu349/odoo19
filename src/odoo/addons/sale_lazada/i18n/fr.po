"réessayer."

#. module: sale_lazada
#: model:mail.template,body_html:sale_lazada.inventory_sync_failure
msgid ""
"<style>\n"
"                .lazada_table {\n"
"                    width: 100%;\n"
"                    max-width: 900px;\n"
"                    border-collapse: collapse;\n"
"                }\n"
"\n"
"                .lazada_table th,\n"
"                .lazada_table td {\n"
"                    border: 1px solid #888;\n"
"                }\n"
"\n"
"                .lazada_table th {\n"
"                    white-space: nowrap;\n"
"                }\n"
"\n"
"                .lazada_table thead th {\n"
"                    padding: 0.5em 0.5em;\n"
"                    text-align: center;\n"
"                    border-bottom: 1px solid #888;\n"
"                }\n"
"\n"
"                .lazada_table tbody th,\n"
"                .lazada_table tbody td {\n"
"                    padding: 0.5em 0.5em 1em;\n"
"                    vertical-align: top;\n"
"                }\n"
"            </style>\n"
"            <body><div>\n"
"                <p>The synchronization of the inventory for Lazada Shop\n"
"                    <b><t t-out=\"ctx.get('lazada_shop') or ''\">REF</t></b>\n"
"                    encountered some errors and was not completed.</p>\n"
"                <p>Here are the errors sent by Lazada: </p>\n"
"                <table class=\"lazada_table\">\n"
"                    <thead>\n"
"                        <tr>\n"
"                            <th>Product Internal Reference(s)</th>\n"
"                            <th>Message</th>\n"
"                        </tr>\n"
"                    </thead>\n"
"                    <tbody>\n"
"                        <tr t-foreach=\"ctx.get('error_messages')\" t-as=\"error\">\n"
"                            <th><t t-out=\"', '.join(error['default_codes'])\"/></th>\n"
"                            <td>\n"
"                                <t t-if=\"error['message']\" t-out=\"error['message']\"/>\n"
"                                <t t-else=\"\">An unknown error occurred during the synchronisation with Lazada.\n"
"                                    Unfortunately you need to manually check if the available quantity for the product is correct or not.\n"
"                                    If the problem persists, contact <a href=\"https://www.odoo.com/help/\">Odoo support </a>.\n"
"                                </t>\n"
"                            </td>\n"
"                        </tr>\n"
"                    </tbody>\n"
"                </table>\n"
"            </div>\n"
"        </body>"
msgstr ""
"<style>\n"
"                .lazada_table {\n"
"                    width: 100%;\n"
"                    max-width: 900px;\n"
"                    border-collapse: collapse;\n"
"                }\n"
"\n"
"                .lazada_table th,\n"
"                .lazada_table td {\n"
"                    border: 1px solid #888;\n"
"                }\n"
"\n"
"                .lazada_table th {\n"
"                    white-space: nowrap;\n"
"                }\n"
"\n"
"                .lazada_table thead th {\n"
"                    padding: 0.5em 0.5em;\n"
"                    text-align: center;\n"
"                    border-bottom: 1px solid #888;\n"
"                }\n"
"\n"
"                .lazada_table tbody th,\n"
"                .lazada_table tbody td {\n"
"                    padding: 0.5em 0.5em 1em;\n"
"                    vertical-align: top;\n"
"                }\n"
"            </style>\n"
"            <body><div>\n"
"                <p>La synchronisation de l’inventaire pour la boutique "
"Lazada\n"
"                    <b><t t-out=\"ctx.get('lazada_shop') or ''\">REF</t></b>"
"\n"
"                    a rencontré des erreurs et n’a pas pu être effectuée.</p>"
"\n"
"                <p>Voici les erreurs envoyées par Lazada : </p>\n"
"                <table class=\"lazada_table\">\n"
"                    <thead>\n"
"                        <tr>\n"
"                            <th>Référence(s) interne(s) du produit</th>\n"
"                            <th>Message</th>\n"
"                        </tr>\n"
"                    </thead>\n"
"                    <tbody>\n"
"                        <tr t-foreach=\"ctx.get('error_messages')\" t-"
"as=\"error\">\n"
"                            <th><t t-out=\"', '.join(error['default_codes'])"
"\"/></th>\n"
"                            <td>\n"
"                                <t t-if=\"error['message']\" t-"
"out=\"error['message']\"/>\n"
"                                <t t-else=\"\">Une erreur inconnue s’est "
"produite lors de la synchronisation avec Lazada.\n"
"                                    Malheureusement, vous devez vérifier "
"manuellement si la quantité disponible du produit est correcte.\n"
"                                    Si le problème persiste, contactez le <a "
"href=\"https://www.odoo.com/help/\">support Odoo</a>.\n"
"                                </t>\n"
"                            </td>\n"
"                        </tr>\n"
"                    </tbody>\n"
"                </table>\n"
"            </div>\n"
"        </body>"

