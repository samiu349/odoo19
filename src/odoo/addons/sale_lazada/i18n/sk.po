#. module: sale_lazada
#: model:mail.template,body_html:sale_lazada.order_sync_failure
msgid ""
"<div>\n"
"                <p>The synchronization of the Lazada order with reference <t t-out=\"ctx.get('lazada_order_ref') or ''\">REF</t> encountered an error and was not completed.</p>\n"
"                <p>Unless the order is cancelled in Lazada, no other synchronization will be attempted.</p>\n"
"                <p>To schedule a new synchronization attempt, proceed as follows:\n"
"                    </p><ol>\n"
"                        <li>Enter the Developer Tools.</li>\n"
"                        <li>Open the form of the Lazada Shop on which the order was placed.</li>\n"
"                        <li>Navigate to the Order Follow-up tab.</li>\n"
"                        <li>Set a date for <em>Last Order Synchronization Date</em> that is anterior to the last status update of the order.</li>\n"
"                        <li>Save the changes and click on the <em>SYNC ORDERS</em> button.</li>\n"
"                    </ol>\n"
"                \n"
"                <p>If the problem persists, contact <a href=\"https://www.odoo.com/help/\">Odoo support</a>.</p>\n"
"            </div>\n"
"        "
msgstr ""
"<div>\n"
"                <p>Pri synchronizácii objednávky z Lazada s referenčným "
"číslom <t t-out=\"ctx.get('lazada_order_ref') or ''\">REF</t> došlo k chybe "
"a synchronizácia nebola dokončená.</p>\n"
"                <p>Pokiaľ nebude objednávka zrušená v Lazada, nebude sa "
"vykonávať žiadna ďalšia synchronizácia.</p>\n"
"                <p>Ak chcete naplánovať nový pokus o synchronizáciu, "
"postupujte takto:\n"
"                    </p><ol>\n"
"                        <li>Prejdite do nástrojov pre vývojárov.</li>\n"
"                        <li>Otvorte stránku obchodu Lazada, na ktorej bola "
"objednávka zadaná.</li>\n"
"                        <li>Prejdite na kartu Sledovanie objednávok.</li>\n"
"                        <li>Nastavte dátum pre <em>Dátum poslednej "
"synchronizácie objednávky</em> tak, aby bol skorší ako dátum poslednej "
"aktualizácie stavu objednávky.</li>\n"
"                        <li>Uložte zmeny a kliknite na tlačidlo <em>SYNC "
"ORDERS</em>.</li>\n"
"                    </ol>\n"
"                \n"
"                <p>Ak problém pretrváva, kontaktujte <a href=\"https://"
"www.odoo.com/help/\">podporu Odoo</a>.</p>\n"
"            </div>\n"
"        "

#. module: sale_lazada
