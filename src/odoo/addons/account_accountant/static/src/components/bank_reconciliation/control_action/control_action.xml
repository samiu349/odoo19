<?xml version="1.0" encoding="UTF-8"?>
<templates>
    <t t-name="account_accountant.BankRecKanbanControlPanel" t-inherit="web.ControlPanel" t-inherit-mode="primary">
        <xpath expr="//div[hasclass('o_control_panel_actions')]" position="inside">
            <div t-if="selectedStatementLines.length and !ui.isSmall" class="d-flex w-100 gap-1">
                <t t-foreach="buttonsToDisplay" t-as="button" t-key="button_index">
                    <BankRecButton t-props="button"/>
                </t>
                <Dropdown>
                    <button class="btn btn-secondary">
                        <i class="oi oi-ellipsis-v"/>
                    </button>
                    <t t-set-slot="content">
                        <t t-foreach="reconcileModelsToDisplay" t-as="model" t-key="model.id">
                            <DropdownItem class="'btn btn-link'" onSelected.bind="() => this.triggerReconciliationModel(model.id)">
                                <t t-esc="model.display_name"/>
                            </DropdownItem>
                        </t>
                        <t t-foreach="extraButtonToDisplay" t-as="button" t-key="button_index">
                            <DropdownItem class="'btn btn-link'" onSelected.bind="button.action">
                                <t t-esc="button.label"/>
                            </DropdownItem>
                        </t>
                    </t>
                </Dropdown>
            </div>
        </xpath>
    </t>
</templates>
