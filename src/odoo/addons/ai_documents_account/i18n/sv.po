#. odoo-python
#: code:addons/ai_documents_account/wizard/ai_documents_sort.py:0
msgid "%(b_open)sContracts & NDAs%(b_close)s go to the %(legal)s folder."
msgstr ""
"%(b_open)sKontrakt och sekretessavtal%(b_close)s hamnar i mappen %(legal)s."

#. module: ai_documents_account
#. odoo-python
#: code:addons/ai_documents_account/wizard/ai_documents_sort.py:0
msgid ""
"%(b_open)sInsurance contracts%(b_close)s go to the %(insurance)s folder."
msgstr "%(b_open)sFörsäkringsavtal%(b_close)s hamnar i mappen %(insurance)s."

#. module: ai_documents_account
#: model:ir.model.fields,field_description:ai_documents_account.field_documents_document__ai_document_or_env_company_id
msgid "AI Company"
msgstr "AI-företag"

#. module: ai_documents_account
#: model:ir.model,name:ai_documents_account.model_ai_documents_sort
