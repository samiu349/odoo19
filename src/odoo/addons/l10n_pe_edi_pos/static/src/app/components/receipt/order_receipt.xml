<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">
    <t t-name="OrderReceipt" t-inherit="point_of_sale.OrderReceipt" t-inherit-mode="extension">
        <xpath expr="//div[@t-if='order.company.point_of_sale_use_ticket_qr_code and order.finalized']" position="before">
            <t t-if="order.company.country_id?.code === 'PE' and Object.keys(this.order.l10n_pe_edi_data).length !== 0">
                <div class="mt-2 text-center">
                    <b>Amount In Word:</b> <t t-out="this.amountToText"/>
                </div>
                <div class="gap-2 d-flex flex-row pt-3" style="font-size: 75%;">
                    <div>
                        <img t-if="this.peEdiQrcode" id="pe_edi_data_qr" t-att-src="this.peEdiQrcode" class="mt-1"/>
                    </div>
                    <div class="w-100 ms-1">
                        <div class="fw-bolder">
                            Summary:
                        </div>
                        <div class="portal-url text-break">
                            <t t-out="this.summary"/>
                        </div>
                    </div>
                </div>
            </t>
        </xpath>
    </t>
</templates>
