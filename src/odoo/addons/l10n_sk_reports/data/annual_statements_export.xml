<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id='sk_annual_statements_template'>
        <dokument>
            <hlavicka>
                <datumK>
                    <den><t t-out="to_date.day"/></den>
                    <mesiac><t t-out="to_date.month"/></mesiac>
                    <rok><t t-out="to_date.year"/></rok>
                </datumK>
                <dic><t t-out="company.income_tax_id"/></dic>
                <ico><t t-out="company.company_registry"/></ico>
                <skNace>
                    <k1><t t-out="SK_NACE_code1"/></k1>
                    <k2><t t-out="SK_NACE_code2"/></k2>
                    <k3><t t-out="SK_NACE_code3"/></k3>
                </skNace>
                <typUzavierky>
                    <riadna><t t-out="regular"/></riadna>
                    <mimoriadna><t t-out="extraordinary"/></mimoriadna>
                    <priebezna><t t-out="interim"/></priebezna>
                    <mala><t t-out="small"/></mala>
                    <velka><t t-out="large"/></velka>
                </typUzavierky>
                <obdobie>
                    <od>
                        <mesiac><t t-out="from_date.month"/></mesiac>
                        <rok><t t-out="from_date.year"/></rok>
                    </od>
                    <do>
                        <mesiac><t t-out="to_date.month"/></mesiac>
                        <rok><t t-out="to_date.year"/></rok>
                    </do>
                </obdobie>
                <bPredObdobie>
                    <od>
                        <mesiac><t t-out="previous_from_date.month"/></mesiac>
                        <rok><t t-out="previous_from_date.year"/></rok>
                    </od>
                    <do>
                        <mesiac><t t-out="previous_to_date.month"/></mesiac>
                        <rok><t t-out="previous_to_date.year"/></rok>
                    </do>
                </bPredObdobie>
                <prilozeneSucasti>
                    <suvaha>1</suvaha>
                    <vykazZiskovStrat>1</vykazZiskovStrat>
                    <poznamky>0</poznamky>
                </prilozeneSucasti>
                <uctJednotka>
                    <obchMeno>
                        <riadok><t t-out="company.name"/></riadok>
                        <riadok/>
                    </obchMeno>
                    <sidlo>
                        <ulica><t t-out="street_name"/></ulica>
                        <cislo><t t-out="street_number"/></cislo>
                        <psc><t t-out="company.zip"/></psc>
                        <obec><t t-out="company.city"/></obec>
                        <oznObchodReg>
                            <riadok><t t-out="company.trade_registry"/></riadok>
                            <riadok/>
                        </oznObchodReg>
                        <telefon><t t-out="company.phone"/></telefon>
                        <fax/>
                        <email><t t-out="company.email"/></email>
                    </sidlo>
                </uctJednotka>
                <datZostavenia><t t-out="creation_date"/></datZostavenia>
                <datSchvalenia/>
            </hlavicka>
            <telo>
                <ucPod1Suvaha/>
                <ucPod2VykazZS/>
            </telo>
        </dokument>
    </template>
</odoo>
