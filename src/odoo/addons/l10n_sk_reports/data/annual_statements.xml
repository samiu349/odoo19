<?xml version="1.0" encoding="utf-8"?>
<odoo>
<data auto_sequence="1">
    <record id="l10n_sk_reports_bs_pl" model="account.report">
        <field name="name">Balance Sheet + Profit and Loss</field>
        <field name="name@sk">Súvaha + Výkaz ziskov a strát</field>
        <field name="filter_date_range" eval="True"/>
        <field name="filter_unfold_all" eval="True"/>
        <field name="filter_period_comparison" eval="False"/>
        <field name="filter_journals" eval="True"/>
        <field name="country_id" ref="base.sk"/>
        <field name="root_report_id" ref="account_reports.annual_statements"/>
        <field name="custom_handler_model_id" ref="model_l10n_sk_annual_statements_report_handler"/>
        <field name="section_report_ids"
            eval="[Command.set([ref('l10n_sk_reports_balance_sheet'),
            ref('l10n_sk_reports_profit_loss'),
            ])]"
        />
    </record>
</data>
</odoo>
