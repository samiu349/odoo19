<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="product_pos_category_form_view_inherit" model="ir.ui.view">
        <field name="name">pos.category.form</field>
        <field name="model">pos.category</field>
        <field name="inherit_id" ref="point_of_sale.product_pos_category_form_view" />
        <field name="arch" type="xml">
            <xpath expr="//group[1]" position="after">
                <group name="platform_order" groups="base.group_system" string="Platform Order Settings">
                    <field name="service_hours_id"/>
                </group>
            </xpath>
        </field>
    </record>

</odoo>
