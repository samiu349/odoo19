<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">
    <t t-name="pos_platform_order.OrderDisplay" t-inherit="point_of_sale.OrderDisplay" t-inherit-mode="extension">
        <xpath expr="//div[hasclass('order-summary')]" position="after">
            <div t-if="order.isPlatformOrder" class="gap-1 py-2 border-bottom fw-bolder lh-sm">
                <div class="d-flex flex-column gap-1 p-2 fw-bolder lh-sm">
                    <div class="subentry d-flex justify-content-between w-100 fs-6 text-muted">
                        <span>Status</span>
                    </div>
                    <div class="d-flex justify-content-between w-100 fs-2">
                        <span t-esc="order.platformOrderStatus" />
                    </div>
                </div>
                <div class="d-flex flex-column gap-1 p-2 fw-bolder lh-sm border-top">
                    <div class="subentry d-flex justify-content-between w-100 fs-6 text-muted">
                        <span>PIN</span>
                        <span t-if="order.platform_order_rider_name">Rider</span>
                    </div>
                    <div class="d-flex justify-content-between w-100 fs-2">
                        <span t-esc="order.platform_order_pin" />
                        <span t-if="order.platform_order_rider_name" t-esc="order.platform_order_rider_name" />
                    </div>
                </div>
            </div>
        </xpath>
    </t>
</templates>
