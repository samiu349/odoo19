<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.l10n_gt_edi_pos</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="point_of_sale.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//block[@id='pos_bills_and_receipts_section']" position="inside">
                <setting id="l10n_gt_final_consumer_limit"
                         help="Maximum POS sale amount for unidentified customers (Consumidor Final, or any customer missing a valid Identification Type or Number)."
                         invisible="country_code != 'GT'">
                    <field name="pos_l10n_gt_final_consumer_limit"/>
                </setting>
            </xpath>
        </field>
    </record>
</odoo>
